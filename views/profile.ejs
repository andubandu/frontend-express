<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-900">
    <header class="bg-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 py-6 sm:px-6 lg:px-8">
            <h1 class="text-3xl font-bold text-gray-900">Profile</h1>
        </div>
    </header>
    
    <div id="profile" class="max-w-4xl mx-auto mt-6 p-6 bg-white shadow-lg rounded-lg"></div>
    
    <script>
        async function getProfile() {
            const username = window.location.pathname.split("/").pop();
            try {
                const userResponse = await axios.get(`https://express-auth-so6r.vercel.app/users/${username}`);
                const postResponse = await axios.get(`https://express-auth-so6r.vercel.app/posts`);
                const userData = userResponse.data;
                const postList = postResponse.data.filter(post => post.author.username === userData.username);

                const profileContainer = document.getElementById('profile');
                profileContainer.innerHTML = `
                    <div class="flex items-center space-x-4">
                        <img src="${userData.avatar}" alt="${userData.username}" class="w-24 h-24 rounded-full border border-gray-300">
                        <div>
                            <h2 class="text-2xl font-semibold">${userData.username}</h2>
                            <p class="text-gray-600">Email: ${userData.email}</p>
                            <p class="text-gray-500">Joined: ${new Date(userData.createdAt).toLocaleDateString()}</p>
                        </div>
                    </div>
                    <h3 class="mt-6 text-xl font-semibold">Posts</h3>
                    <div id="posts" class="mt-4 space-y-4"></div>
                `;
                
                const postsContainer = document.getElementById('posts');
                postList.forEach(post => {
                    const postElement = document.createElement('div');
                    postElement.className = "bg-gray-50 p-4 rounded-lg shadow";
                    postElement.innerHTML = `
                        <h4 class="text-lg font-medium">${post.title}</h4>
                        <p class="text-gray-700">${post.content}</p>
                        ${post.media ? 
                            post.media.type === 'image' ?
                                `<img src="${post.media.url}" alt="${post.title}" class="w-full mt-2 rounded">` :
                            post.media.type === 'video' ?
                                `<video src="${post.media.url}" controls class="w-full mt-2 rounded"></video>` :
                            ''
                        : ''}
                    `;
                    postsContainer.appendChild(postElement);
                });
            } catch (error) {
                console.error("Error fetching profile:", error);
            }
        }
        
        getProfile();
    </script>
</body>
</html>
