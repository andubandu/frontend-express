<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user.username %>'s Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-900">
    <header class="bg-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 py-6 sm:px-6 lg:px-8">
            <h1 class="text-3xl font-bold text-gray-900">Profile</h1>
        </div>
    </header>

    <div class="max-w-4xl mx-auto mt-6 p-6 bg-white shadow-lg rounded-lg">
        <div class="flex items-center space-x-4">
            <img src="<%= user.avatar %>" alt="<%= user.username %>" class="w-24 h-24 rounded-full border border-gray-300">
            <div>
                <h2 class="text-2xl font-semibold"><%= user.username %></h2>
                <p class="text-gray-600">Email: <%= user.email %></p>
                <p class="text-gray-500">Joined: <%= new Date(user.createdAt).toLocaleDateString() %></p>
            </div>
        </div>

        <h3 class="mt-6 text-xl font-semibold">Posts</h3>
        <div class="mt-4 space-y-4">
            <% posts.forEach(post => { %>
                <div class="bg-gray-50 p-4 rounded-lg shadow">
                    <h4 class="text-lg font-medium"><%= post.title %></h4>
                    <p class="text-gray-700"><%= post.content %></p>
                    <% if (post.media) { %>
                        <% if (post.media.type === 'image') { %>
                            <img src="<%= post.media.url %>" alt="<%= post.title %>" class="w-full mt-2 rounded">
                        <% } else if (post.media.type === 'video') { %>
                            <video src="<%= post.media.url %>" controls class="w-full mt-2 rounded"></video>
                        <% } %>
                    <% } %>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>
